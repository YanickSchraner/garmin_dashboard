# Garmin Connect credentials (used if no stored tokens exist)
EMAIL=<your garmin email address>
PASSWORD=<your garmin password>
GARMIN_TOKEN_STORE=~/.garminconnect

# Personalisation
# DISPLAY_NAME is used as fallback when the Garmin API does not return a name.
# If left empty and Garmin returns no name, the dashboard shows "Athlete".
DISPLAY_NAME=

# Goals
ANNUAL_RUN_GOAL=104
WEEKLY_RUN_GOAL=2

# Docker / Frontend
# URL the *browser* uses to reach the backend API.
# On a Raspberry Pi, replace localhost with the Pi's IP address so the
# dashboard works from other devices on the same network too.
NUXT_PUBLIC_API_BASE=http://localhost:8000
